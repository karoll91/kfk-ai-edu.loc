# Ushbu faylni .env ga nusxalab, o'z ma'lumotlaringizni kiriting
# .env fayli hech qachon git ga qo'shilmaydi!

# Ilova
APP_NAME=kfkAiEdu
APP_URL=http://kfkaiedu.loc
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=Asia/Tashkent

# Ma'lumotlar bazasi
DB_HOST=localhost
DB_PORT=3306
DB_NAME=kfkaiedu_db
DB_USER=root
DB_PASS=your_password_here
DB_CHARSET=utf8mb4

# JWT
JWT_SECRET=change_this_to_random_64_char_string
JWT_EXPIRE_HOURS=1
JWT_REFRESH_DAYS=30

# Claude API (Anthropic)
CLAUDE_API_KEY=sk-ant-api03-xxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=1000

# Email (parolni tiklash uchun)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@kompmind.uz
MAIL_FROM_NAME=KompMind
